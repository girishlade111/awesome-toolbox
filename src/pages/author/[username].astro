---
import Layout from '../layouts/Layout.astro';
import resourcesData from '../data/resources.json';

export function getStaticPaths() {
  const authorCounts: Record<string, number> = {};
  resourcesData.resources.forEach((r) => {
    authorCounts[r.author] = (authorCounts[r.author] || 0) + 1;
  });

  const authors = Object.entries(authorCounts).map(([username, count]) => ({
    username,
    url: resourcesData.resources.find((r) => r.author === username)?.authorUrl || '',
    resourceCount: count,
  }));

  return authors.map((author) => ({
    params: { username: author.username },
    props: { author, resources: resourcesData.resources.filter((r) => r.author === author.username) },
  }));
}

interface Props {
  author: { username: string; url: string; resourceCount: number };
  resources: typeof resourcesData.resources;
}

const { author, resources } = Astro.props;
---

<Layout title={author.username}>
  <section class="author-hero">
    <div class="container">
      <div class="author-profile">
        <div class="author-avatar">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
          </svg>
        </div>
        <div class="author-info">
          <h1>{author.username}</h1>
          <p class="resource-count">{author.resourceCount} resource{author.resourceCount !== 1 ? 's' : ''}</p>
          <a href={author.url} target="_blank" rel="noopener" class="github-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.26.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            View GitHub Profile
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="author-resources section">
    <div class="container">
      <h2 class="section-title">Contributed Resources</h2>
      <div class="resources-grid">
        {resources.map((resource) => (
          <a href={`/resource/${resource.id}`} class="resource-card card">
            <span class={`badge badge-${resource.category}`}>{resource.category}</span>
            <h3>{resource.title}</h3>
            <p>{resource.description}</p>
            <div class="resource-meta">
              <span class="date">{resource.addedAt}</span>
              <div class="tags">
                {resource.tags.slice(0, 3).map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .author-hero {
    padding: 80px 0 40px;
    background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(99, 102, 241, 0.1), transparent);
  }

  .author-profile {
    display: flex;
    align-items: center;
    gap: 24px;
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .author-avatar {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100px;
    height: 100px;
    background: var(--bg-surface);
    border: 2px solid var(--border);
    border-radius: 50%;
    color: var(--text-muted);
  }

  .author-info h1 {
    margin-bottom: 8px;
  }

  .resource-count {
    color: var(--text-secondary);
    margin-bottom: 12px;
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    color: var(--text-secondary);
    transition: all 0.2s ease;
  }

  .github-link:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .section-title {
    margin-bottom: 32px;
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 24px;
  }

  .resource-card {
    color: inherit;
  }

  .resource-card:hover {
    color: inherit;
  }

  .resource-card h3 {
    margin: 16px 0 12px;
    font-size: 1.25rem;
  }

  .resource-card p {
    color: var(--text-secondary);
    font-size: 0.875rem;
    margin-bottom: 16px;
  }

  .resource-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .date {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tag {
    padding: 4px 8px;
    background: var(--bg-elevated);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .author-profile {
      flex-direction: column;
    }
  }
</style>