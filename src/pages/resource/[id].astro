---
import Layout from '../layouts/Layout.astro';
import resourcesData from '../data/resources.json';
import { categories } from '../types';

export function getStaticPaths() {
  return resourcesData.resources.map((resource) => ({
    params: { id: resource.id },
    props: { resource },
  }));
}

interface Props {
  resource: typeof resourcesData.resources[0];
}

const { resource } = Astro.props;

const relatedResources = resourcesData.resources
  .filter((r) => r.id !== resource.id && (r.category === resource.category || r.tags.some((t) => resource.tags.includes(t))))
  .slice(0, 4);

const category = categories.find((c) => c.id === resource.category);
---

<Layout title={resource.title}>
  <section class="resource-hero">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/browse">Browse</a>
        <span>/</span>
        <a href={`/browse?category=${resource.category}`}>{category?.label}</a>
        <span>/</span>
        <span class="current">{resource.title}</span>
      </nav>
    </div>
  </section>

  <section class="resource-content section">
    <div class="container">
      <div class="resource-layout">
        <div class="resource-main">
          <div class="resource-header">
            <span class={`badge badge-${resource.category}`}>{resource.category}</span>
            <h1>{resource.title}</h1>
            <p class="resource-description">{resource.description}</p>
          </div>

          <div class="resource-tags">
            {resource.tags.map((tag) => (
              <a href={`/browse?tag=${encodeURIComponent(tag)}`} class="tag">{tag}</a>
            ))}
          </div>

          <div class="resource-actions">
            <a href={resource.url} target="_blank" rel="noopener" class="btn btn-primary">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              Visit Resource
            </a>
            <button class="btn btn-secondary share-btn" data-url={Astro.url.href} data-title={resource.title}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="18" cy="5" r="3"/>
                <circle cx="6" cy="12" r="3"/>
                <circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
              Share
            </button>
          </div>

          {relatedResources.length > 0 && (
            <div class="related-section">
              <h2>Related Resources</h2>
              <div class="related-grid">
                {relatedResources.map((related) => (
                  <a href={`/resource/${related.id}`} class="related-card card">
                    <span class={`badge badge-${related.category}`}>{related.category}</span>
                    <h3>{related.title}</h3>
                    <p>{related.description}</p>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>

        <aside class="resource-sidebar">
          <div class="sidebar-card">
            <h3>Author</h3>
            <a href={resource.authorUrl} target="_blank" rel="noopener" class="author-link">
              <div class="author-avatar">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </svg>
              </div>
              <span>{resource.author}</span>
            </a>
          </div>

          <div class="sidebar-card">
            <h3>Details</h3>
            <div class="detail-row">
              <span class="detail-label">Added</span>
              <span class="detail-value">{resource.addedAt}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Category</span>
              <span class="detail-value">{category?.icon} {category?.label}</span>
            </div>
          </div>

          <div class="sidebar-card">
            <h3>All Tags</h3>
            <div class="tags-list">
              {resource.tags.map((tag) => (
                <a href={`/browse?tag=${encodeURIComponent(tag)}`} class="tag-pill">{tag}</a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll('.share-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = (btn as HTMLButtonElement).dataset.url || '';
      const title = (btn as HTMLButtonElement).dataset.title || '';
      if (navigator.share) {
        await navigator.share({ title, url });
      } else {
        await navigator.clipboard.writeText(url);
        alert('Link copied to clipboard!');
      }
    });
  });
</script>

<style>
  .resource-hero {
    padding: 40px 0 20px;
    background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(99, 102, 241, 0.1), transparent);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .breadcrumb a {
    color: var(--text-secondary);
  }

  .breadcrumb .current {
    color: var(--text-primary);
  }

  .resource-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 48px;
    align-items: start;
  }

  .resource-header {
    margin-bottom: 24px;
  }

  .resource-header h1 {
    margin: 16px 0;
  }

  .resource-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .resource-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 32px;
  }

  .tag {
    padding: 6px 14px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 0.875rem;
    color: var(--text-secondary);
    transition: all 0.2s ease;
  }

  .tag:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .resource-actions {
    display: flex;
    gap: 16px;
    margin-bottom: 48px;
  }

  .related-section h2 {
    margin-bottom: 24px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .related-card {
    color: inherit;
  }

  .related-card:hover {
    color: inherit;
  }

  .related-card h3 {
    margin: 12px 0 8px;
    font-size: 1.125rem;
  }

  .related-card p {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .resource-sidebar {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .sidebar-card {
    padding: 24px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .sidebar-card h3 {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .author-link {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--text-primary);
    font-weight: 500;
  }

  .author-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--bg-elevated);
    border-radius: 50%;
    color: var(--text-muted);
  }

  .detail-row {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
  }

  .detail-row:last-child {
    border-bottom: none;
  }

  .detail-label {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .detail-value {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-pill {
    padding: 4px 10px;
    background: var(--bg-elevated);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  @media (max-width: 900px) {
    .resource-layout {
      grid-template-columns: 1fr;
    }

    .resource-sidebar {
      position: static;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
    }
  }

  @media (max-width: 640px) {
    .related-grid {
      grid-template-columns: 1fr;
    }

    .resource-actions {
      flex-direction: column;
    }
  }
</style>