---
import Layout from '../layouts/Layout.astro';
import resourcesData from '../data/resources.json';
import collectionsData from '../data/collections.json';

const collections = collectionsData.collections.map((collection) => {
  const resources = collection.resourceIds
    .map((id) => resourcesData.resources.find((r) => r.id === id))
    .filter(Boolean);
  return { ...collection, resources };
});

const featuredCollections = collections.filter((c) => c.featured);
const regularCollections = collections.filter((c) => !c.featured);
---

<Layout title="Collections">
  <section class="collections-hero">
    <div class="container">
      <h1>Collections</h1>
      <p>Curated sets of resources organized by theme and use case</p>
    </div>
  </section>

  <section class="collections-content section">
    <div class="container">
      {featuredCollections.length > 0 && (
        <div class="featured-section">
          <h2 class="section-title">Featured Collections</h2>
          <div class="featured-grid">
            {featuredCollections.map((collection) => (
              <a href={`/browse?collection=${collection.id}`} class="featured-card" style={`--accent: ${collection.color}`}>
                <div class="featured-icon">{collection.icon}</div>
                <div class="featured-content">
                  <h3>{collection.title}</h3>
                  <p>{collection.description}</p>
                  <span class="resource-count">{collection.resources.length} resources</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="all-collections">
        <h2 class="section-title">All Collections</h2>
        <div class="collections-grid">
          {regularCollections.map((collection) => (
            <a href={`/browse?collection=${collection.id}`} class="collection-card card" style={`--accent: ${collection.color}`}>
              <div class="collection-icon">{collection.icon}</div>
              <h3>{collection.title}</h3>
              <p>{collection.description}</p>
              <span class="resource-count">{collection.resources.length} resources</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .collections-hero {
    padding: 80px 0 40px;
    text-align: center;
    background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(139, 92, 246, 0.1), transparent);
  }

  .collections-hero h1 {
    margin-bottom: 12px;
  }

  .collections-hero p {
    color: var(--text-secondary);
  }

  .section-title {
    margin-bottom: 32px;
  }

  .featured-section {
    margin-bottom: 64px;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
    gap: 24px;
  }

  .featured-card {
    display: flex;
    gap: 24px;
    padding: 28px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    transition: all 0.2s ease;
    color: inherit;
  }

  .featured-card:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
    box-shadow: 0 0 30px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .featured-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: color-mix(in srgb, var(--accent) 15%, transparent);
    border-radius: var(--radius-md);
    font-size: 2rem;
  }

  .featured-content h3 {
    font-size: 1.25rem;
    margin-bottom: 8px;
  }

  .featured-content p {
    color: var(--text-secondary);
    font-size: 0.875rem;
    margin-bottom: 12px;
  }

  .resource-count {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .collections-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }

  .collection-card {
    position: relative;
    color: inherit;
  }

  .collection-card:hover {
    color: inherit;
  }

  .collection-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: color-mix(in srgb, var(--accent) 15%, transparent);
    border-radius: var(--radius-md);
    font-size: 1.5rem;
    margin-bottom: 16px;
  }

  .collection-card h3 {
    font-size: 1.125rem;
    margin-bottom: 8px;
  }

  .collection-card p {
    color: var(--text-secondary);
    font-size: 0.875rem;
    margin-bottom: 16px;
  }

  .resource-count {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }

    .featured-card {
      flex-direction: column;
      text-align: center;
    }

    .featured-icon {
      margin: 0 auto;
    }
  }
</style>