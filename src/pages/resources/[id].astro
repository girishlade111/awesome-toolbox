---
import Layout from '../../layouts/Layout.astro';
import resourcesData from '../../data/resources.json';
import { categories } from '../../types';

export async function getStaticPaths() {
  return resourcesData.resources.map((resource) => ({
    params: { id: resource.id },
    props: { resource },
  }));
}

interface Props {
  resource: typeof resourcesData.resources[0];
}

const { resource } = Astro.props;
const categoryInfo = categories.find(c => c.id === resource.category);

// Find related resources (same category, excluding current)
const relatedResources = resourcesData.resources
  .filter(r => r.category === resource.category && r.id !== resource.id)
  .slice(0, 3);

const url = `https://yourusername.github.io/devhub/resources/${resource.id}`;
const ogDescription = resource.description;
const ogTitle = `${resource.title} | DevHub`;
---

<Layout title={resource.title} description={ogDescription}>
  <article class="resource-detail">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Home</a>
        <span class="separator">/</span>
        <a href="/browse">Browse</a>
        <span class="separator">/</span>
        <span class="current">{resource.title}</span>
      </nav>

      <div class="resource-header">
        <div class="resource-badges">
          <span class={`badge badge-${resource.category}`}>
            {categoryInfo?.icon} {categoryInfo?.label}
          </span>
        </div>
        <h1>{resource.title}</h1>
        <p class="resource-description">{resource.description}</p>
        
        <div class="resource-actions">
          <a href={resource.url} target="_blank" rel="noopener" class="btn btn-primary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
            Visit Resource
          </a>
          <button class="btn btn-secondary share-btn" data-url={url}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="18" cy="5" r="3"/>
              <circle cx="6" cy="12" r="3"/>
              <circle cx="18" cy="19" r="3"/>
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
              <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
            </svg>
            Share
          </button>
        </div>
      </div>

      <div class="resource-info">
        <div class="info-card">
          <h3>Details</h3>
          <dl class="details-list">
            <div class="detail-item">
              <dt>Author</dt>
              <dd>
                <a href={resource.authorUrl} target="_blank" rel="noopener" class="author-link">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                  {resource.author}
                </a>
              </dd>
            </div>
            <div class="detail-item">
              <dt>Added</dt>
              <dd>{new Date(resource.addedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</dd>
            </div>
            <div class="detail-item">
              <dt>Category</dt>
              <dd>{categoryInfo?.label}</dd>
            </div>
          </dl>
        </div>

        <div class="tags-card">
          <h3>Tags</h3>
          <div class="tags-list">
            {resource.tags.map(tag => (
              <a href={`/browse?tag=${encodeURIComponent(tag)}`} class="tag-pill">{tag}</a>
            ))}
          </div>
        </div>
      </div>

      {relatedResources.length > 0 && (
        <div class="related-section">
          <h2>Related Resources</h2>
          <div class="related-grid">
            {relatedResources.map(related => {
              const relatedCategory = categories.find(c => c.id === related.category);
              return (
                <a href={`/resources/${related.id}`} class="related-card">
                  <span class={`badge badge-${related.category}`}>
                    {relatedCategory?.icon} {relatedCategory?.label}
                  </span>
                  <h3>{related.title}</h3>
                  <p>{related.description}</p>
                  <span class="related-author">by {related.author}</span>
                </a>
              );
            })}
          </div>
        </div>
      )}
    </div>
  </article>
</Layout>

<style>
  .resource-detail {
    padding-top: 72px;
    min-height: 100vh;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 32px;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .breadcrumb a {
    color: var(--text-secondary);
    transition: color 0.2s ease;
  }

  .breadcrumb a:hover {
    color: var(--primary);
  }

  .breadcrumb .separator {
    color: var(--text-muted);
  }

  .breadcrumb .current {
    color: var(--text-primary);
  }

  .resource-header {
    max-width: 800px;
    margin-bottom: 48px;
  }

  .resource-badges {
    margin-bottom: 16px;
  }

  .resource-header h1 {
    margin-bottom: 16px;
  }

  .resource-description {
    color: var(--text-secondary);
    font-size: 1.125rem;
    line-height: 1.6;
    margin-bottom: 32px;
  }

  .resource-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: var(--radius-md);
    font-weight: 500;
    font-size: 1rem;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--primary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--primary-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
  }

  .btn-secondary {
    background: var(--bg-elevated);
    color: var(--text-primary);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .resource-info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 64px;
  }

  .info-card, .tags-card {
    padding: 24px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .info-card h3, .tags-card h3 {
    font-size: 1rem;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-muted);
  }

  .details-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .detail-item dt {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .detail-item dd {
    color: var(--text-primary);
    margin: 0;
  }

  .author-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--primary);
  }

  .author-link:hover {
    color: var(--primary-hover);
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-pill {
    display: inline-block;
    padding: 8px 16px;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 0.875rem;
    color: var(--text-secondary);
    transition: all 0.2s ease;
  }

  .tag-pill:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .related-section {
    margin-bottom: 64px;
  }

  .related-section h2 {
    margin-bottom: 32px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }

  .related-card {
    display: block;
    padding: 24px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    color: inherit;
    transition: all 0.2s ease;
  }

  .related-card:hover {
    transform: translateY(-4px);
    border-color: var(--primary);
    box-shadow: var(--shadow-glow);
    color: inherit;
  }

  .related-card .badge {
    display: inline-block;
    margin-bottom: 12px;
  }

  .related-card h3 {
    font-size: 1.125rem;
    margin-bottom: 8px;
  }

  .related-card p {
    color: var(--text-secondary);
    font-size: 0.875rem;
    margin-bottom: 16px;
  }

  .related-author {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .share-toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    padding: 12px 24px;
    background: var(--success);
    color: white;
    border-radius: var(--radius-md);
    font-weight: 500;
    z-index: 1000;
    animation: slideIn 0.3s ease;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 900px) {
    .resource-info {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .resource-actions {
      flex-direction: column;
    }

    .btn {
      width: 100%;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Share functionality
  const shareBtn = document.querySelector('.share-btn');
  
  shareBtn?.addEventListener('click', async () => {
    const url = shareBtn.dataset.url;
    
    if (navigator.share) {
      try {
        await navigator.share({
          title: document.querySelector('h1')?.textContent,
          url: url
        });
      } catch (err) {
        console.log('Share cancelled');
      }
    } else {
      // Fallback: copy to clipboard
      try {
        await navigator.clipboard.writeText(url);
        showToast('Link copied to clipboard!');
      } catch (err) {
        console.error('Failed to copy:', err);
      }
    }
  });

  function showToast(message: string) {
    const existing = document.querySelector('.share-toast');
    if (existing) existing.remove();

    const toast = document.createElement('div');
    toast.className = 'share-toast';
    toast.textContent = message;
    document.body.appendChild(toast);

    setTimeout(() => {
      toast.remove();
    }, 3000);
  }
</script>
