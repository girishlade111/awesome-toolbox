---
import Layout from '../layouts/Layout.astro';
import resourcesData from '../data/resources.json';
import { categories } from '../types';

const resources = resourcesData.resources.slice(0, 6);
const featuredTutorials = resourcesData.tutorials.slice(0, 3);

const authorCounts: Record<string, { count: number; url: string }> = {};
resourcesData.resources.forEach((r) => {
  if (!authorCounts[r.author]) {
    authorCounts[r.author] = { count: 0, url: r.authorUrl };
  }
  authorCounts[r.author].count++;
});
const topAuthors = Object.entries(authorCounts)
  .sort((a, b) => b[1].count - a[1].count)
  .slice(0, 5);
---

<Layout title="Home">
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <h1 class="animate-fade-in">Supercharge Your <span class="gradient-text">Development</span></h1>
      <p class="hero-subtitle animate-slide-up">
        Discover community-built agents, prompts, instructions, and plugins to get the most out of your developer tool.
      </p>
      <div class="hero-search animate-slide-up">
        <form action="/browse" method="get">
          <input 
            type="text" 
            name="q" 
            placeholder="Search for agents, prompts, plugins..." 
            class="search-input"
          />
          <button type="submit" class="btn btn-primary">Search</button>
        </form>
      </div>
      <div class="hero-stats animate-fade-in">
        <div class="stat">
          <span class="stat-number">{resourcesData.resources.length}</span>
          <span class="stat-label">Resources</span>
        </div>
        <div class="stat">
          <span class="stat-number">{resourcesData.tutorials.length}</span>
          <span class="stat-label">Tutorials</span>
        </div>
        <div class="stat">
          <span class="stat-number">{categories.length}</span>
          <span class="stat-label">Categories</span>
        </div>
      </div>
    </div>
  </section>

  <section class="categories-section section">
    <div class="container">
      <h2 class="section-title">Browse by Category</h2>
      <div class="categories-grid">
        {categories.map((cat, index) => (
          <a href={`/browse?category=${cat.id}`} class="category-card" style={`animation-delay: ${index * 0.1}s`}>
            <span class="category-icon">{cat.icon}</span>
            <h3>{cat.label}</h3>
            <p>{resourcesData.resources.filter(r => r.category === cat.id).length} items</p>
          </a>
        ))}
        <a href="/collections" class="category-card">
          <span class="category-icon">📚</span>
          <h3>Collections</h3>
          <p>Curated bundles</p>
        </a>
      </div>
    </div>
  </section>

  <section class="featured-section section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Featured Resources</h2>
        <a href="/browse" class="view-all">View all →</a>
      </div>
      <div class="resources-grid">
        {resources.map((resource) => (
          <a href={`/resource/${resource.id}`} class="resource-card card">
            <span class={`badge badge-${resource.category}`}>{resource.category}</span>
            <h3>{resource.title}</h3>
            <p>{resource.description}</p>
            <div class="resource-meta">
              <a href={`/author/${resource.author}`} class="author">by {resource.author}</a>
              <div class="tags">
                {resource.tags.slice(0, 3).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="authors-section section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Top Contributors</h2>
        <a href="/browse" class="view-all">View all →</a>
      </div>
      <div class="authors-grid">
        {topAuthors.map(([username, data]) => (
          <a href={`/author/${username}`} class="author-card card">
            <div class="author-avatar">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
              </svg>
            </div>
            <div class="author-info">
              <h3>{username}</h3>
              <span class="resource-count">{data.count} resource{data.count !== 1 ? 's' : ''}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="learn-section section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Learning Hub</h2>
        <a href="/learn" class="view-all">Explore all →</a>
      </div>
      <div class="tutorials-grid">
        {featuredTutorials.map((tutorial) => (
          <a href={tutorial.url} class="tutorial-card card">
            <div class="tutorial-header">
              <span class={`badge badge-${tutorial.difficulty}`}>{tutorial.difficulty}</span>
              <span class="duration">{tutorial.duration}</span>
            </div>
            <h3>{tutorial.title}</h3>
            <p>{tutorial.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section section">
    <div class="container">
      <div class="cta-content">
        <h2>Have something to share?</h2>
        <p>Contribute your own agents, prompts, and plugins to help the community grow.</p>
        <a href="/submit" class="btn btn-primary">Submit Your Resource</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    padding: 120px 0 80px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(99, 102, 241, 0.15), transparent),
      radial-gradient(ellipse 60% 40% at 80% 60%, rgba(34, 211, 238, 0.1), transparent);
    z-index: -1;
  }

  .hero-content {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero h1 {
    margin-bottom: 24px;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 40px;
  }

  .hero-search {
    margin-bottom: 48px;
  }

  .hero-search form {
    display: flex;
    gap: 12px;
    max-width: 600px;
    margin: 0 auto;
  }

  .search-input {
    flex: 1;
    padding: 16px 24px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-size: 1rem;
    transition: all 0.2s ease;
  }

  .search-input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 48px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--primary);
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 32px;
  }

  .section-title {
    margin-bottom: 0;
  }

  .view-all {
    color: var(--primary);
    font-weight: 500;
    font-size: 0.875rem;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 24px;
  }

  .category-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 32px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-align: center;
    transition: all 0.2s ease;
    animation: fadeIn 0.5s ease forwards;
    opacity: 0;
  }

  .category-card:hover {
    border-color: var(--primary);
    transform: translateY(-4px);
    box-shadow: var(--shadow-glow);
  }

  .category-icon {
    font-size: 2.5rem;
    margin-bottom: 16px;
  }

  .category-card h3 {
    font-size: 1.25rem;
    margin-bottom: 8px;
  }

  .category-card p {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 24px;
  }

  .resource-card {
    display: block;
    color: inherit;
  }

  .resource-card:hover {
    color: inherit;
  }

  .resource-card h3 {
    margin: 16px 0 12px;
    font-size: 1.25rem;
  }

  .resource-card p {
    color: var(--text-secondary);
    font-size: 0.875rem;
    margin-bottom: 16px;
  }

  .resource-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .author {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .author a {
    color: var(--primary);
  }

  .tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tag {
    padding: 4px 8px;
    background: var(--bg-elevated);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .tutorials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }

  .tutorial-card {
    display: block;
    color: inherit;
  }

  .tutorial-card:hover {
    color: inherit;
  }

  .tutorial-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .duration {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .tutorial-card h3 {
    font-size: 1.125rem;
    margin-bottom: 8px;
  }

  .tutorial-card p {
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  .cta-section {
    text-align: center;
  }

  .cta-content {
    max-width: 500px;
    margin: 0 auto;
    padding: 48px;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(34, 211, 238, 0.1));
    border-radius: var(--radius-xl);
    border: 1px solid var(--border);
  }

  .cta-content h2 {
    margin-bottom: 12px;
  }

  .cta-content p {
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  .authors-section {
    background: var(--bg-surface);
  }

  .authors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 20px;
  }

  .author-card {
    display: flex;
    align-items: center;
    gap: 16px;
    color: inherit;
  }

  .author-card:hover {
    color: inherit;
  }

  .author-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--bg-elevated);
    border-radius: 50%;
    color: var(--text-muted);
  }

  .author-info h3 {
    font-size: 1rem;
    margin-bottom: 4px;
  }

  .resource-count {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .hero-search form {
      flex-direction: column;
    }

    .hero-stats {
      gap: 24px;
    }

    .stat-number {
      font-size: 1.5rem;
    }

    .resources-grid,
    .tutorials-grid {
      grid-template-columns: 1fr;
    }

    .cta-content {
      padding: 32px 24px;
    }
  }
</style>