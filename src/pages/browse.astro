---
import Layout from '../layouts/Layout.astro';
import resourcesData from '../data/resources.json';
import { categories } from '../types';

const allTags = [...new Set(resourcesData.resources.flatMap(r => r.tags))].sort();

const url = Astro.url;
const query = url.searchParams.get('q') || '';
const categoryFilter = url.searchParams.get('category') || '';
const tagFilter = url.searchParams.get('tag') || '';

let filtered = resourcesData.resources;

if (query) {
  const q = query.toLowerCase();
  filtered = filtered.filter(r => 
    r.title.toLowerCase().includes(q) ||
    r.description.toLowerCase().includes(q) ||
    r.tags.some(t => t.toLowerCase().includes(q))
  );
}

if (categoryFilter) {
  filtered = filtered.filter(r => r.category === categoryFilter);
}

if (tagFilter) {
  filtered = filtered.filter(r => r.tags.includes(tagFilter));
}
---

<Layout title="Browse Resources">
  <section class="browse-hero">
    <div class="container">
      <h1>Browse Resources</h1>
      <p>Find the perfect agent, prompt, instruction, or plugin for your needs</p>
    </div>
  </section>

  <section class="browse-content section">
    <div class="container">
      <div class="browse-layout">
        <aside class="filters-sidebar">
          <div class="filter-section">
            <h3>Search</h3>
            <form method="get" class="filter-search">
              <input 
                type="text" 
                name="q" 
                value={query}
                placeholder="Search resources..."
                class="filter-input"
              />
              {categoryFilter && <input type="hidden" name="category" value={categoryFilter} />}
              {tagFilter && <input type="hidden" name="tag" value={tagFilter} />}
            </form>
          </div>

          <div class="filter-section">
            <h3>Category</h3>
            <div class="filter-options">
              <a href="/browse" class={`filter-option ${!categoryFilter ? 'active' : ''}`}>
                All Categories
              </a>
              {categories.map(cat => (
                <a 
                  href={`/browse?category=${cat.id}${query ? `&q=${encodeURIComponent(query)}` : ''}`}
                  class={`filter-option ${categoryFilter === cat.id ? 'active' : ''}`}
                >
                  {cat.icon} {cat.label}
                </a>
              ))}
            </div>
          </div>

          <div class="filter-section">
            <h3>Popular Tags</h3>
            <div class="tags-cloud">
              {allTags.slice(0, 12).map(tag => (
                <a 
                  href={`/browse?tag=${encodeURIComponent(tag)}${categoryFilter ? `&category=${categoryFilter}` : ''}`}
                  class={`tag-pill ${tagFilter === tag ? 'active' : ''}`}
                >
                  {tag}
                </a>
              ))}
            </div>
          </div>

          {(categoryFilter || tagFilter || query) && (
            <a href="/browse" class="clear-filters">Clear all filters</a>
          )}
        </aside>

        <div class="results-section">
          <div class="results-header">
            <p class="results-count">{filtered.length} resource{filtered.length !== 1 ? 's' : ''} found</p>
            <div class="active-filters">
              {categoryFilter && (
                <span class="filter-tag">
                  Category: {categories.find(c => c.id === categoryFilter)?.label}
                  <a href={`/browse?${new URLSearchParams({ ...(query ? { q: query } : {}), ...(tagFilter ? { tag: tagFilter } : {}) }).toString()}`}>×</a>
                </span>
              )}
              {tagFilter && (
                <span class="filter-tag">
                  Tag: {tagFilter}
                  <a href={`/browse?${new URLSearchParams({ ...(query ? { q: query } : {}), ...(categoryFilter ? { category: categoryFilter } : {}) }).toString()}`}>×</a>
                </span>
              )}
            </div>
          </div>

          {filtered.length > 0 ? (
            <div class="resources-grid">
              {filtered.map((resource) => (
                <a href={resource.url} target="_blank" rel="noopener" class="resource-card card">
                  <div class="card-header">
                    <span class={`badge badge-${resource.category}`}>{resource.category}</span>
                    <span class="date">{resource.addedAt}</span>
                  </div>
                  <h3>{resource.title}</h3>
                  <p>{resource.description}</p>
                  <div class="resource-meta">
                    <span class="author">by <a href={resource.authorUrl} target="_blank" rel="noopener">{resource.author}</a></span>
                    <div class="tags">
                      {resource.tags.map(tag => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="no-results">
              <h3>No resources found</h3>
              <p>Try adjusting your search or filters</p>
              <a href="/browse" class="btn btn-secondary">Clear filters</a>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .browse-hero {
    padding: 80px 0 40px;
    text-align: center;
    background: 
      radial-gradient(ellipse 60% 40% at 50% 0%, rgba(99, 102, 241, 0.1), transparent);
  }

  .browse-hero h1 {
    margin-bottom: 12px;
  }

  .browse-hero p {
    color: var(--text-secondary);
  }

  .browse-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 48px;
  }

  .filters-sidebar {
    position: sticky;
    top: 100px;
    height: fit-content;
  }

  .filter-section {
    margin-bottom: 32px;
  }

  .filter-section h3 {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .filter-search {
    display: flex;
    gap: 8px;
  }

  .filter-input {
    flex: 1;
    padding: 10px 14px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-size: 0.875rem;
  }

  .filter-input:focus {
    outline: none;
    border-color: var(--primary);
  }

  .filter-options {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .filter-option {
    display: block;
    padding: 10px 14px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: 0.875rem;
    transition: all 0.2s ease;
  }

  .filter-option:hover {
    border-color: var(--primary);
    color: var(--text-primary);
  }

  .filter-option.active {
    background: var(--primary);
    border-color: var(--primary);
    color: white;
  }

  .tags-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-pill {
    display: inline-block;
    padding: 6px 12px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 0.75rem;
    color: var(--text-secondary);
    transition: all 0.2s ease;
  }

  .tag-pill:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .tag-pill.active {
    background: var(--primary);
    border-color: var(--primary);
    color: white;
  }

  .clear-filters {
    display: inline-block;
    padding: 10px 16px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--error);
    font-size: 0.875rem;
    transition: all 0.2s ease;
  }

  .clear-filters:hover {
    background: rgba(239, 68, 68, 0.1);
    border-color: var(--error);
  }

  .results-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 16px;
  }

  .results-count {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .active-filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .filter-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    background: var(--bg-elevated);
    border-radius: 100px;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .filter-tag a {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1;
  }

  .filter-tag a:hover {
    color: var(--error);
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }

  .resource-card {
    display: block;
    color: inherit;
  }

  .resource-card:hover {
    color: inherit;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .date {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .resource-card h3 {
    font-size: 1.125rem;
    margin-bottom: 8px;
  }

  .resource-card p {
    color: var(--text-secondary);
    font-size: 0.875rem;
    margin-bottom: 16px;
  }

  .resource-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .author {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .author a {
    color: var(--primary);
  }

  .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .tag {
    padding: 3px 8px;
    background: var(--bg-elevated);
    border-radius: var(--radius-sm);
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .no-results {
    text-align: center;
    padding: 64px 24px;
    background: var(--bg-surface);
    border-radius: var(--radius-lg);
  }

  .no-results h3 {
    margin-bottom: 8px;
  }

  .no-results p {
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  @media (max-width: 900px) {
    .browse-layout {
      grid-template-columns: 1fr;
    }

    .filters-sidebar {
      position: static;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 24px;
    }

    .clear-filters {
      grid-column: 1 / -1;
      text-align: center;
    }
  }

  @media (max-width: 640px) {
    .filters-sidebar {
      grid-template-columns: 1fr;
    }
  }
</style>