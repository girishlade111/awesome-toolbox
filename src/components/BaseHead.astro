---
interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: URL;
  jsonLd?: Record<string, any>;
}

const {
  title,
  description = "A curated directory of community-built agents, prompts, plugins, and tutorials.",
  image = "/favicon.svg",
  canonicalURL = new URL(Astro.url.pathname, Astro.site),
  jsonLd,
} = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title} | DevHub</title>
<meta name="title" content={`${title} | DevHub`} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={`${title} | DevHub`} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />
<meta property="og:site_name" content="DevHub" />
<meta property="og:locale" content="en_US" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={`${title} | DevHub`} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />

<!-- Theme color -->
<meta name="theme-color" content="#6366f1" />

<!-- Preload Fuse.js -->
<script src="https://cdn.jsdelivr.net/npm/fuse.js@7.0.0/dist/fuse.min.js" defer></script>

<!-- JSON-LD Structured Data -->
{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}
