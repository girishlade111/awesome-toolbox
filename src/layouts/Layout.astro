---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  jsonLd?: Record<string, any>;
}

const { title, description, image, jsonLd } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} jsonLd={jsonLd} />
    <link rel="alternate" type="application/rss+xml" title="DevHub RSS Feed" href="/rss.xml" />
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        const prefers = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', stored || prefers);
      })();
    </script>
  </head>
  <body>
    <Navigation />

    <main id="main-content">
      <slot />
    </main>

    <Footer />

    <script>
      // Smooth scroll for anchor links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const targetId = this.getAttribute('href');
          if (targetId === '#') return;
          const targetElement = document.querySelector(targetId);
          if (targetElement) {
            targetElement.scrollIntoView({
              behavior: 'smooth'
            });
          }
        });
      });
    </script>
  </body>
</html>

<style>
  main {
    min-height: calc(100vh - 200px);
    padding-top: 72px; /* Height of the navigation bar */
  }

  @media (max-width: 640px) {
    main {
      padding-top: 64px;
    }
  }
</style>